{
    "version": "0.2.0",
    "configurations": [
        {
            // Direct launch with mp.spawn — best for local debugging.
            // VSCode auto-discovers spawned workers via subProcess.
            // Just press F5 and set breakpoints normally.
            "name": "Debug: mp.spawn (local)",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/.venv/bin/python",
            "program": "${workspaceFolder}/train.py",
            "args": [],
            "env": {
                "WORLD_SIZE": "8"
            },
            "subProcess": true,
            "justMyCode": true
        },
        {
            // Per-rank attach for torchrun on remote compute nodes.
            // Start torchrun first, then attach.
            "name": "Attach Rank 0 (torchrun)",
            "type": "debugpy",
            "request": "attach",
            "connect": { "host": "localhost", "port": 5678 },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}",
                    "remoteRoot": "${workspaceFolder}"
                }
            ],
            "justMyCode": true
        },
        {
            "name": "Attach Rank 1 (torchrun)",
            "type": "debugpy",
            "request": "attach",
            "connect": { "host": "localhost", "port": 5679 },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}",
                    "remoteRoot": "${workspaceFolder}"
                }
            ],
            "justMyCode": true
        }
    ],
    "compounds": [
        {
            "name": "Attach All Ranks (torchrun)",
            "configurations": ["Attach Rank 0 (torchrun)", "Attach Rank 1 (torchrun)"]
        }
    ]
}
